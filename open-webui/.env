TZ=America/Santiago

# Postgres compartido (base "openwebui" ya creada en docker/postgres)
DATABASE_URL=postgresql://openwebui:${PG_OPENWEBUI_PASSWORD}@postgres:5432/openwebui

# Firma de sesiones/JWT
WEBUI_SECRET_KEY=${OPENWEBUI_SECRET_KEY}

# Usa LiteLLM (docker/litellm) como backend unico para todos los modelos
OPENAI_API_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=${LITELLM_MASTER_KEY}

# El primer usuario que se registra queda como admin sin importar este flag.
# Deja "true" solo hasta crear tu cuenta; luego cambialo a "false".
ENABLE_SIGNUP=true

WEBUI_NAME=Apex Lab Chat
