TZ=America/Santiago
RAILS_ENV=production
NODE_ENV=production

SECRET_KEY_BASE=${CHATWOOT_SECRET_KEY_BASE}

FRONTEND_URL=http://100.94.184.123:3007
ENABLE_ACCOUNT_SIGNUP=false
DEFAULT_LOCALE=es

# Postgres dedicado de este stack (requiere extensión pgvector para Captain/IA)
POSTGRES_HOST=chatwoot-postgres
POSTGRES_USERNAME=${CHATWOOT_PG_USER}
POSTGRES_PASSWORD=${CHATWOOT_PG_PASSWORD}
POSTGRES_DATABASE=chatwoot

# Redis compartido (docker/redis), db lógica 2 para no mezclar keys con otros servicios
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/2

MAILER_SENDER_EMAIL=Apex SpA <no-reply@apexspa.cl>
ACTIVE_STORAGE_SERVICE=local
