PAPERLESS_TIME_ZONE=America/Santiago
PAPERLESS_OCR_LANGUAGE=spa+eng

PAPERLESS_SECRET_KEY=${PAPERLESS_SECRET_KEY}

# Postgres compartido (base "paperless" ya creada en docker/postgres)
PAPERLESS_DBHOST=postgres
PAPERLESS_DBPORT=5432
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=${PG_PAPERLESS_USER}
PAPERLESS_DBPASS=${PG_PAPERLESS_PASSWORD}

# Redis compartido (docker/redis), db lógica 1 para no mezclar keys con otros servicios
PAPERLESS_REDIS=redis://:${REDIS_PASSWORD}@redis:6379/1

PAPERLESS_URL=http://100.94.184.123:8650
PAPERLESS_ALLOWED_HOSTS=100.94.184.123,localhost

# Crea el superusuario automáticamente en el primer arranque
PAPERLESS_ADMIN_USER=${PAPERLESS_ADMIN_USER}
PAPERLESS_ADMIN_PASSWORD=${PAPERLESS_ADMIN_PASSWORD}
PAPERLESS_ADMIN_MAIL=luciano.badilla@outlook.com
