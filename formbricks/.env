TZ=America/Santiago

WEBAPP_URL=http://100.94.184.123:3006

# Postgres dedicado de este stack (requiere pgvector; usuario "postgres" propio, no el compartido)
POSTGRES_PASSWORD=${FORMBRICKS_PG_PASSWORD}
DATABASE_URL=postgresql://postgres:${FORMBRICKS_PG_PASSWORD}@formbricks-postgres:5432/formbricks?schema=public
HUB_DATABASE_URL=postgresql://postgres:${FORMBRICKS_PG_PASSWORD}@formbricks-postgres:5432/formbricks?sslmode=disable

REDIS_URL=redis://formbricks-redis:6379

NEXTAUTH_SECRET=${FORMBRICKS_NEXTAUTH_SECRET}
ENCRYPTION_KEY=${FORMBRICKS_ENCRYPTION_KEY}
CRON_SECRET=${FORMBRICKS_CRON_SECRET}

HUB_API_KEY=${FORMBRICKS_HUB_API_KEY}
HUB_API_URL=http://formbricks-hub:8080

CUBEJS_API_URL=http://formbricks-cube:4000
CUBEJS_API_SECRET=${FORMBRICKS_CUBEJS_API_SECRET}
