TZ=America/Santiago

PORT=3000
NEXT_PUBLIC_WEBAPP_URL=http://100.94.184.123:3005

NEXTAUTH_SECRET=${DOCUMENSO_NEXTAUTH_SECRET}
NEXT_PRIVATE_ENCRYPTION_KEY=${DOCUMENSO_ENCRYPTION_KEY}
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=${DOCUMENSO_ENCRYPTION_SECONDARY_KEY}

# Postgres compartido (base "documenso" ya creada en docker/postgres)
NEXT_PRIVATE_DATABASE_URL=postgresql://documenso:${PG_DOCUMENSO_PASSWORD}@postgres:5432/documenso
NEXT_PRIVATE_DIRECT_DATABASE_URL=postgresql://documenso:${PG_DOCUMENSO_PASSWORD}@postgres:5432/documenso

# Certificado de firma autofirmado (./certs/cert.p12) - válido para pruebas internas.
# Para firmas con validez legal ante terceros, reemplaza cert.p12 por un certificado
# real emitido por una autoridad certificadora y actualiza la passphrase.
NEXT_PRIVATE_SIGNING_PASSPHRASE=${DOCUMENSO_SIGNING_PASSPHRASE}

# SMTP: completar antes de usar el envío de solicitudes de firma por correo
NEXT_PRIVATE_SMTP_TRANSPORT=smtp-auth
NEXT_PRIVATE_SMTP_HOST=
NEXT_PRIVATE_SMTP_PORT=587
NEXT_PRIVATE_SMTP_USERNAME=
NEXT_PRIVATE_SMTP_PASSWORD=
NEXT_PRIVATE_SMTP_FROM_NAME=Apex SpA
NEXT_PRIVATE_SMTP_FROM_ADDRESS=no-reply@apexspa.cl
