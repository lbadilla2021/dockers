TZ=America/Santiago
SANDBOX_USER_ID=1000

# Usa LiteLLM (docker/litellm) como backend unico de modelos.
# "claude-sonnet-5" esta definido en docker/litellm/config/config.yaml;
# cambia el nombre si usas otro model_name de ese archivo.
LLM_MODEL=openai/claude-sonnet-5
LLM_BASE_URL=http://litellm:4000
LLM_API_KEY=${LITELLM_MASTER_KEY}

LOG_ALL_EVENTS=true

# Opcional: token de GitHub para que el agente pueda clonar/pushear repos
# privados. Tambien se puede configurar despues desde la UI (Settings).
GITHUB_TOKEN=
