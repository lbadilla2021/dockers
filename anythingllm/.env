TZ=America/Santiago
STORAGE_DIR=/app/server/storage

JWT_SECRET=${ANYTHINGLLM_JWT_SECRET}
SIG_KEY=${ANYTHINGLLM_SIG_KEY}
SIG_SALT=${ANYTHINGLLM_SIG_SALT}

# Usa LiteLLM (docker/litellm) como backend generic-openai.
# "claude-sonnet-5" esta definido en docker/litellm/config/config.yaml;
# cambia el nombre si usas otro model_name de ese archivo.
LLM_PROVIDER=generic-openai
GENERIC_OPEN_AI_BASE_PATH=http://litellm:4000/v1
GENERIC_OPEN_AI_MODEL_PREF=claude-sonnet-5
GENERIC_OPEN_AI_MODEL_TOKEN_LIMIT=8192
GENERIC_OPEN_AI_API_KEY=${LITELLM_MASTER_KEY}

# Vector DB compartido (docker/qdrant)
VECTOR_DB=qdrant
QDRANT_ENDPOINT=http://qdrant:6333
QDRANT_API_KEY=${QDRANT_API_KEY}

# Embeddings nativas (sin dependencias externas)
EMBEDDING_ENGINE=native

DISABLE_TELEMETRY=true
