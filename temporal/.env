TZ=America/Santiago

# Postgres compartido (bases "temporal" y "temporal_visibility" ya creadas
# en docker/postgres/init/01-app-databases.sql)
DB=postgres12
DB_PORT=5432
POSTGRES_SEEDS=postgres
POSTGRES_USER=${PG_TEMPORAL_USER}
POSTGRES_PWD=${PG_TEMPORAL_PASSWORD}
SQL_PASSWORD=${PG_TEMPORAL_PASSWORD}
